# The port the backend server will run on
PORT=5000

# Node environment: 'development' or 'production'
NODE_ENV=production

# The secret key for signing JSON Web Tokens. Must be a strong, random string in production.
JWT_SECRET=super_secret_jwt_key_change_me_in_production

# The secret key for signing Refresh Tokens. Must be different from JWT_SECRET and very strong.
REFRESH_TOKEN_SECRET=super_secret_refresh_key_change_me_in_production

# The URL of your deployed application. If deployed as a monolith, this should match the public domain (e.g., https://my-expense-tracker.com).
# If running locally, http://localhost:5000
CLIENT_URL=http://localhost:5000

# The MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/expense-split

# Token expiry durations
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
